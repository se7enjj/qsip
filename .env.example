# ============================================================
# QSIP – Quantum-Safe Internet Protocol Suite
# .env.example — Copy this to .env and fill in real values.
#                NEVER commit .env to version control.
# ============================================================

# ----- Application -----
QSIP_ENV=development               # development | staging | production
QSIP_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
QSIP_VERSION=0.1.0

# ----- Cryptographic Algorithms -----
# Key Encapsulation Mechanism (NIST PQC FIPS 203)
QSIP_KEM_ALGORITHM=Kyber1024       # Kyber512 | Kyber768 | Kyber1024

# Digital Signature Algorithm (NIST PQC FIPS 204)
QSIP_SIG_ALGORITHM=Dilithium5      # Dilithium2 | Dilithium3 | Dilithium5

# Hash algorithm for all internal operations
QSIP_HASH_ALGORITHM=SHA3-512

# Enable hybrid mode (classical + PQC) for transition period
QSIP_HYBRID_MODE=true

# ----- Identity Layer -----
# Path to local identity keystore (NEVER commit the actual file)
QSIP_IDENTITY_KEYSTORE_PATH=~/.qsip/keystore.enc

# Passphrase for encrypting the local keystore (use a strong random value)
QSIP_KEYSTORE_PASSPHRASE=CHANGE_ME_USE_STRONG_RANDOM_VALUE

# Identity registry endpoint (for publishing/resolving public keys)
QSIP_IDENTITY_REGISTRY_URL=https://registry.qsip.example.com

# ----- Zero-Knowledge Proofs -----
# ZK backend: python_native | external_service
QSIP_ZK_BACKEND=python_native

# Maximum proof size in bytes
QSIP_ZK_MAX_PROOF_SIZE=65536

# ----- PQC DNS -----
# Upstream DNS resolver with DNSSEC support
QSIP_DNS_RESOLVER=9.9.9.9         # Quad9 (DNSSEC-validating)
QSIP_DNS_RESOLVER_PORT=853        # DoT port
QSIP_DNS_ENABLE_DOT=true          # DNS-over-TLS
QSIP_DNS_ENABLE_DOH=false         # DNS-over-HTTPS

# Trust anchor for DNSSEC root zone (leave default unless you know what you're doing)
QSIP_DNS_ROOT_TRUST_ANCHOR=. IN DS 20326 8 2 E06D44B80B8F1D39A95C0B0D7C65D08458E880409BBC683457104237C7F8EC8D

# ----- PQ Email -----
# SMTP settings for outbound email
QSIP_SMTP_HOST=smtp.example.com
QSIP_SMTP_PORT=587
QSIP_SMTP_USER=your_email@example.com
QSIP_SMTP_PASSWORD=CHANGE_ME

# IMAP settings for inbound email
QSIP_IMAP_HOST=imap.example.com
QSIP_IMAP_PORT=993
QSIP_IMAP_USER=your_email@example.com
QSIP_IMAP_PASSWORD=CHANGE_ME

# Max email size in bytes (default 25 MB)
QSIP_EMAIL_MAX_SIZE=26214400

# PQEP header version to emit
QSIP_PQEP_VERSION=1

# ----- Key Rotation -----
# Days before a key should be considered for rotation
QSIP_KEY_ROTATION_DAYS=90

# ----- Audit & Compliance -----
# Enable cryptographic audit log
QSIP_AUDIT_LOG_ENABLED=true
QSIP_AUDIT_LOG_PATH=~/.qsip/audit.log

# Sign audit log entries (prevents tampering)
QSIP_AUDIT_LOG_SIGNED=true
